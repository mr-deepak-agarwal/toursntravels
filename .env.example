# Copy this file to .env.local and fill in real values before going live.
# Gmail: use an "App Password" (not your normal password) if using Gmail SMTP.
# Or use a transactional provider like Resend/Brevo/SendGrid SMTP credentials.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO_EMAIL=hello@yourdomain.com
