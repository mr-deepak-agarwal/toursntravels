# Copy this file to .env.local and fill in values from
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used ONLY by app/api/enquiry/route.ts on the server to save enquiries,
# bypassing RLS. Never expose this to the browser (no NEXT_PUBLIC_ prefix).
# Get it from Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notifications when a form is submitted (Resend: https://resend.com)
# 1. Sign up at resend.com and create an API key -> RESEND_API_KEY
# 2. Verify a domain in Resend, then set NOTIFY_FROM to an address on it
#    e.g. "Zorvana Tours <enquiries@zorvanatours.com>"
#    (until a domain is verified you can leave NOTIFY_FROM unset — it will
#    fall back to Resend's shared onboarding@resend.dev sender)
# 3. Set NOTIFY_TO to the inbox that should receive enquiry emails
RESEND_API_KEY=your-resend-api-key
NOTIFY_FROM="Zorvana Tours <onboarding@resend.dev>"
NOTIFY_EMAIL=you@example.com
